<Project>
	<!-- ==== 경로/트리플릿 공통 설정 ==== -->
	<PropertyGroup>
		<!-- vcpkg 루트 경로: 필요시 본인 경로로 수정 -->
		<VcpkgRoot>D:\vcpkg</VcpkgRoot>

		<!-- 정적/동적 CRT 및 라이브러리 트리플릿 -->
		<TripletStatic>x64-windows-static-md</TripletStatic>
		<TripletDynamic>x64-windows</TripletDynamic>
	</PropertyGroup>

	<!-- ==== 공통: 포함 디렉터리 ==== -->
	<ItemDefinitionGroup>
		<ClCompile>
			<AdditionalIncludeDirectories>
				$(VcpkgRoot)\installed\$(TripletStatic)\include;
				$(VcpkgRoot)\installed\$(TripletDynamic)\include;
				%(AdditionalIncludeDirectories)
			</AdditionalIncludeDirectories>
		</ClCompile>
	</ItemDefinitionGroup>

	<!-- ==== Debug 전용 설정 ==== -->
	<ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
		<ClCompile>
			<!-- Debug: DLL CRT (/MDd) -->
			<RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
		</ClCompile>

		<Link>
			<!-- 라이브러리 경로 -->
			<AdditionalLibraryDirectories>
				$(VcpkgRoot)\installed\$(TripletDynamic)\debug\lib;
				$(VcpkgRoot)\installed\$(TripletStatic)\debug\lib;
				%(AdditionalLibraryDirectories)
			</AdditionalLibraryDirectories>

			<!-- 라이브러리 링크 -->
			<AdditionalDependencies>
				physx_64.lib;
				PhysXCommon_64.lib;
				PhysXFoundation_64.lib;
				PhysXExtensions_static_64.lib;
				PhysXPvdSDK_static_64.lib;
				PhysXCharacterKinematic_static_64.lib;
				PhysXCooking_64.lib;

				assimp-vc143-mtd.lib;
				pugixml.lib;

				directxtk.lib;
				directxtex.lib;
				imguid.lib;

				%(AdditionalDependencies)
			</AdditionalDependencies>
		</Link>

		<!-- DLL 자동 복사 -->
		<PostBuildEvent>
			<Command>
				xcopy /Y /D "$(VcpkgRoot)\installed\$(TripletDynamic)\debug\bin\assimp-vc143-mtd.dll" "$(OutDir)"
			</Command>
		</PostBuildEvent>
	</ItemDefinitionGroup>

	<!-- ==== Release 전용 설정 ==== -->
	<ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
		<ClCompile>
			<!-- Release: DLL CRT (/MD) -->
			<RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
		</ClCompile>

		<Link>
			<!-- 라이브러리 경로 -->
			<AdditionalLibraryDirectories>
				$(VcpkgRoot)\installed\$(TripletDynamic)\lib;
				$(VcpkgRoot)\installed\$(TripletStatic)\lib;
				%(AdditionalLibraryDirectories)
			</AdditionalLibraryDirectories>

			<!-- 라이브러리 링크 -->
			<AdditionalDependencies>
				physx_64.lib;
				PhysXCommon_64.lib;
				PhysXFoundation_64.lib;
				PhysXExtensions_static_64.lib;
				PhysXPvdSDK_static_64.lib;
				PhysXCharacterKinematic_static_64.lib;
				PhysXCooking_64.lib;

				assimp-vc143-mt.lib;
				pugixml.lib;

				directxtk.lib;
				directxtex.lib;
				imgui.lib;

				%(AdditionalDependencies)
			</AdditionalDependencies>
		</Link>

		<!-- DLL 자동 복사 -->
		<PostBuildEvent>
			<Command>
				xcopy /Y /D "$(VcpkgRoot)\installed\$(TripletDynamic)\bin\assimp-vc143-mt.dll" "$(OutDir)"
			</Command>
		</PostBuildEvent>
	</ItemDefinitionGroup>
</Project>